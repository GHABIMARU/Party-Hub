<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="32dp"
        android:paddingBottom="20dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/theme_picker_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:textColor="@color/text_primary"/>

        <TextView
            android:id="@+id/tv_selected_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/theme_picker_instruction"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textColor="#FFF0B429"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="@drawable/bg_card"/>

    </LinearLayout>

    <!-- Theme grid — rows built in Java, centered -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <!-- This LinearLayout holds rows of 3 tiles each, all centered -->
        <LinearLayout
            android:id="@+id/grid_themes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"/>

    </ScrollView>

    <!-- Bottom bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center">

        <Button
            android:id="@+id/btn_select_all"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/theme_picker_all"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_outline_button"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_start"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="2"
            android:text="@string/theme_picker_start"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_gold_button"
            android:textColor="@color/bg_dark"/>

    </LinearLayout>
</LinearLayout>
