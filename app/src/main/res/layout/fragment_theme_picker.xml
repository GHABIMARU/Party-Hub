<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CHOOSE THEMES"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:textColor="@color/text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/tv_selected_count"
            android:text="Select at least one theme"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

    <!-- Theme grid (scrollable) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <GridLayout
            android:id="@+id/grid_themes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp"
            android:useDefaultMargins="false"/>
    </ScrollView>

    <!-- Bottom bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center">

        <Button
            android:id="@+id/btn_select_all"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="ALL"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_outline_button"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_start"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="2"
            android:text="START GAME"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_gold_button"
            android:textColor="@color/bg_dark"/>
    </LinearLayout>
</LinearLayout>