<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="vertical"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VOTING PHASE"
            android:textSize="11sp"
            android:letterSpacing="0.3"
            android:textColor="@color/text_secondary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vote Out the Spy"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:lineSpacingMultiplier="1.1"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tv_turn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="20sp"
            android:textColor="@color/gold"
            android:layout_marginTop="6dp"
            android:visibility="gone"/>

    </LinearLayout>

    <ListView
        android:id="@+id/list_players"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="8dp"
        android:clipToPadding="false"
        android:padding="2dp"/>

    <Button
        android:id="@+id/btn_confirm_vote"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_gold_button"
        android:text="CONFIRM VOTE"
        android:textColor="@color/bg_dark"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:stateListAnimator="@null"/>

</LinearLayout>