<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <View android:layout_width="match_parent" android:layout_height="2dp"
        android:background="#44E53E3E" android:layout_gravity="top"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/voting_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voting_label"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.25"
                android:textColor="#7BE53E3E"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voting_question"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="@color/text_primary"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tv_turn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/gold"
                android:layout_marginTop="8dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Player list -->
        <ListView
            android:id="@+id/list_players"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@null"
            android:dividerHeight="8dp"/>

        <!-- Confirm button -->
        <Button
            android:id="@+id/btn_confirm_vote"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/voting_confirm"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textColor="@color/bg_dark"
            android:background="@drawable/bg_gold_button"
            android:layout_marginTop="16dp"/>

    </LinearLayout>
</FrameLayout>
