<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ══════════════════════════════════════════════════════════════
         LOCK SCREEN  (id: layout_lock)
         Shown by default. Hidden only while finger holds btn_show_role.
         After player lifts finger, lock reappears automatically.
         Once they tap btn_seen_role → unlockAction() shows role+action.
    ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layout_lock"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg_dark"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:visibility="visible">

        <!-- Progress: "1 / 6" -->
        <TextView
            android:id="@+id/tv_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1 / 6"
            android:textSize="11sp"
            android:letterSpacing="0.3"
            android:textColor="@color/gold"
            android:gravity="end"
            android:layout_marginBottom="24dp"/>

        <!-- Lock icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒"
            android:textSize="52sp"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"/>

        <!-- "Player X, it's your turn" -->
        <TextView
            android:id="@+id/tv_lock_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Player 1, it's your turn"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"/>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tv_lock_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pass the phone to this player.\nNobody else should look at the screen."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="48dp"/>

        <!--
            HOLD-TO-REVEAL button.
            Player must PRESS AND HOLD → role appears.
            Lift finger → role hides instantly.
            Handled by setOnTouchListener in Java.
        -->
        <TextView
            android:id="@+id/btn_show_role"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="👁  HOLD TO SEE YOUR ROLE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="@color/bg_dark"
            android:gravity="center"
            android:background="@drawable/bg_button_gold"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="16dp"/>

        <!--
            "I've seen my role" — styled outlined button,
            appears below HOLD button after first reveal.
        -->
        <TextView
            android:id="@+id/btn_seen_role"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="✅  I'VE SEEN MY ROLE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="@color/gold"
            android:gravity="center"
            android:background="@drawable/bg_button_outline"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════
         ROLE + ACTION SCREEN  (id: scroll_role_visible)

         ✅ FIX: The ScrollView itself has the ID that Java toggles.
         Previously only the inner LinearLayout had an ID, so setting
         its visibility had no effect because the ScrollView parent
         stayed GONE → causing the black screen bug.

         Shown: while finger holds btn_show_role (peek)
                OR after btn_seen_role is tapped (permanent unlock)
         Hidden: when lock screen is active
    ══════════════════════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/scroll_role_visible"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/layout_role_visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="48dp"
            android:paddingBottom="48dp">

            <!-- ── Role card ─────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="28dp"
                android:layout_marginBottom="20dp">

                <!-- Role emoji: 🔴 🩺 🔎 👤 -->
                <TextView
                    android:id="@+id/tv_role_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔴"
                    android:textSize="52sp"
                    android:gravity="center"
                    android:layout_marginBottom="10dp"/>

                <!-- Role name: MAFIA / DOCTOR / DETECTIVE / CIVILIAN -->
                <TextView
                    android:id="@+id/tv_role_name_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MAFIA"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    android:textColor="@color/gold"
                    android:gravity="center"
                    android:layout_marginBottom="14dp"/>

                <!-- Role description + team info (for Mafia) -->
                <TextView
                    android:id="@+id/tv_role_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Role description"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.5"/>

            </LinearLayout>

            <!-- ── Action panel (Mafia / Doctor / Detective only) ── -->
            <LinearLayout
                android:id="@+id/layout_action_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <!-- Title: "Choose a player to eliminate" etc. -->
                <TextView
                    android:id="@+id/tv_action_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Choose a player:"
                    android:textSize="13sp"
                    android:letterSpacing="0.1"
                    android:textColor="@color/gold"
                    android:layout_marginBottom="14dp"/>

                <!-- Player list — built dynamically in Java -->
                <LinearLayout
                    android:id="@+id/ll_action_player_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp"/>

                <!-- Selected player banner -->
                <LinearLayout
                    android:id="@+id/layout_action_selected"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_card"
                    android:padding="12dp"
                    android:layout_marginTop="4dp"
                    android:visibility="invisible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SELECTED  "
                        android:textSize="10sp"
                        android:letterSpacing="0.3"
                        android:textColor="@color/gold"/>

                    <TextView
                        android:id="@+id/tv_action_selected_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textSize="18sp"
                        android:textColor="@color/gold"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ── Confirm button (Mafia / Doctor / Detective) ───── -->
            <TextView
                android:id="@+id/btn_confirm_action"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="CONFIRM — PASS PHONE  →"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="@color/bg_dark"
                android:gravity="center"
                android:background="@drawable/bg_button_gold"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <!-- ── Civilian done button ───────────────────────────── -->
            <TextView
                android:id="@+id/btn_civilian_done"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="GOT IT — PASS PHONE  →"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="@color/bg_dark"
                android:gravity="center"
                android:background="@drawable/bg_button_gold"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

</FrameLayout>