<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <ScrollView
        android:id="@+id/lobby_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/root_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="36dp"
            android:paddingBottom="28dp">

            <!-- HEADER -->
            <LinearLayout
                android:id="@+id/header_block"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🕵️"
                    android:textSize="48sp"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/game_spyfall"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    android:textColor="@color/gold"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lobby_tagline"
                    android:textSize="12sp"
                    android:letterSpacing="0.15"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- MODE PICKER -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MODE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/mode_pass_play"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/lobby_mode_pass_play"
                    android:gravity="center"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_mode_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/mode_host"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/lobby_mode_host"
                    android:gravity="center"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_mode_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/mode_join"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/lobby_mode_join"
                    android:gravity="center"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_mode_button"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- IMPOSTOR SETTINGS -->
            <TextView
                android:id="@+id/impostor_settings_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IMPOSTORS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:id="@+id/impostor_settings_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Number of Impostors"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <Button
                        android:id="@+id/btn_minus_impostor"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="-"
                        android:textSize="18sp"
                        android:textColor="@color/bg_dark"
                        android:background="@drawable/bg_gold_button"
                        android:padding="0dp"/>

                    <TextView
                        android:id="@+id/tv_impostor_count"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textColor="@color/gold"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <Button
                        android:id="@+id/btn_plus_impostor"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="+"
                        android:textSize="18sp"
                        android:textColor="@color/bg_dark"
                        android:background="@drawable/bg_gold_button"
                        android:padding="0dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- INPUT CARD -->
            <LinearLayout
                android:id="@+id/input_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/name_input"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:hint="@string/lobby_name_hint"
                    android:background="@drawable/bg_input"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="14sp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="textPersonName"
                    android:imeOptions="actionDone"/>

                <Button
                    android:id="@+id/add_player_btn"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="+"
                    android:textSize="22sp"
                    android:textColor="@color/bg_dark"
                    android:textStyle="bold"
                    android:background="@drawable/bg_gold_button"
                    android:layout_marginStart="10dp"
                    android:padding="0dp"/>
            </LinearLayout>

            <!-- PLAYERS CARD -->
            <LinearLayout
                android:id="@+id/players_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/lobby_agents_label"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/tv_player_count"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text="0"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50"
                        android:gravity="center"
                        android:background="@drawable/bg_timer_ring"
                        android:backgroundTint="#4CAF50"
                        android:alpha="0.8"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_no_players"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lobby_no_players"
                    android:textSize="13sp"
                    android:textColor="@color/text_hint"
                    android:layout_gravity="center_horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/players_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>

            <!-- START BUTTON -->
            <Button
                android:id="@+id/start_game_btn"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/lobby_start_mission"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:textColor="@color/bg_dark"
                android:background="@drawable/bg_gold_button"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </ScrollView>
</FrameLayout>