<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <View android:layout_width="match_parent" android:layout_height="2dp"
        android:background="#44F0B429" android:layout_gravity="top"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">

        <!-- Phase label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="— INTERROGATION —"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.25"
            android:textColor="@color/gold_dim"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DISCUSSION"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:textColor="@color/text_primary"
            android:layout_marginTop="4dp"/>

        <!-- Timer circle area -->
        <FrameLayout
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:layout_gravity="center_horizontal">

            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:background="@drawable/bg_timer_ring"/>

            <TextView
                android:id="@+id/tv_timer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="60"
                android:textSize="52sp"
                android:textStyle="bold"
                android:textColor="@color/gold"
                android:gravity="center"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find the impostor among you"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="40dp"/>

        <Button
            android:id="@+id/btn_go_to_vote"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="🗳  GO TO VOTE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="@color/bg_dark"
            android:background="@drawable/bg_gold_button"/>

    </LinearLayout>
</FrameLayout>