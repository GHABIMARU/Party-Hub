<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DISCUSSION PHASE"
        android:textSize="11sp"
        android:letterSpacing="0.3"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱"
            android:textSize="40sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="60"
            android:textSize="72sp"
            android:textStyle="bold"
            android:textColor="@color/gold"
            android:gravity="center"
            android:letterSpacing="-0.02"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SECONDS"
            android:textSize="11sp"
            android:letterSpacing="0.25"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Discuss who the impostor might be.\nEveryone knows the location — except the spy."
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btn_go_to_vote"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_gold_button"
        android:text="START VOTING"
        android:textColor="@color/bg_dark"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:stateListAnimator="@null"/>

</LinearLayout>