<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/touch_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:clickable="true"
    android:focusable="true">

    <!-- Top gold bar -->
    <View android:layout_width="match_parent" android:layout_height="2dp"
        android:background="#44F0B429" android:layout_gravity="top"/>

    <!-- INTRO STATE: tap to reveal -->
    <LinearLayout
        android:id="@+id/layout_intro"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👁"
            android:textSize="64sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tv_player_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reveal_agent_default"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:textColor="@color/gold"
            android:gravity="center"
            android:layout_marginTop="20dp"/>

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="@color/gold"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:layout_gravity="center_horizontal"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reveal_hold_instruction"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:textColor="@color/text_secondary"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="░░░░░░░░░░░░░░"
            android:textSize="18sp"
            android:textColor="@color/border"
            android:gravity="center"
            android:layout_marginTop="16dp"/>

        <!-- Continue button — shown after reveal -->
        <Button
            android:id="@+id/next_btn"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:text="@string/reveal_continue"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textColor="@color/bg_dark"
            android:background="@drawable/bg_gold_button"
            android:visibility="gone"
            android:layout_marginTop="36dp"/>

        <TextView
            android:id="@+id/tv_waiting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reveal_waiting"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:visibility="gone"
            android:layout_marginTop="24dp"/>
    </LinearLayout>

    <!-- REVEAL STATE: shown while holding -->
    <LinearLayout
        android:id="@+id/layout_reveal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="invisible">

        <TextView
            android:id="@+id/role_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reveal_role_label"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"/>
    </LinearLayout>

</FrameLayout>